# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/demo/.ext-profile/
/demo/videos/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Windows system and user files (ignore to avoid permission/stash errors)
AppData/
AppData/**
NTUSER.DAT*
Thumbs.db
Desktop.ini
OneDrive/
.cursor/
.git-for-windows-updater
.gitconfig
.lesshst
.node_repl_history
.ssh/
