# X / Twitter API (Vercel env vars)
# Primary bearer token for X API v2
X_BEARER_TOKEN=

# Alternative env var names also supported:
# TWITTER_BEARER_TOKEN=
# X_API_BEARER_TOKEN=

# Default X username to fetch posts from (optional, defaults to "natte")
X_DEFAULT_USERNAME=

# Optional: external AI detector
AI_DETECTOR_URL=
AI_DETECTOR_KEY=

# Neon Database
DATABASE_URL=

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: pre-created Stripe Price IDs (falls back to dynamic pricing)
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_STARTER_YEARLY=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_YEARLY=
# STRIPE_PRICE_BUSINESS_MONTHLY=
# STRIPE_PRICE_BUSINESS_YEARLY=
