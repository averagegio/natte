# X / Twitter Developer API App (Vercel env vars)
# OAuth 2.0 app credentials from https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=

# Optional: OAuth 1.0a consumer keys (stored for reference / future use)
# X_API_KEY=
# X_API_SECRET=

# App-only bearer token for public post fetching (landing page / widget demo)
X_BEARER_TOKEN=

# Alternative env var names also supported:
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_BEARER_TOKEN=
# X_API_BEARER_TOKEN=

# OAuth callback URL for Connect X (defaults to NEXT_PUBLIC_APP_URL + /api/connections/x/callback)
# Use 127.0.0.1 instead of localhost for local dev — X rejects localhost callbacks.
# X_REDIRECT_URI=http://127.0.0.1:3000/api/connections/x/callback

# Sign in with X callback (add this URL in the X Developer Portal too)
# X_LOGIN_REDIRECT_URI=http://127.0.0.1:3000/api/auth/x/callback

# Default X username to fetch posts from (optional, defaults to "natte")
X_DEFAULT_USERNAME=

# App base URL (used for OAuth redirect and Stripe checkout)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Optional: external AI detector (required before allowing detection access)
# AI text detector provider: auto | sapling | winston
# auto = try Sapling first, fall back to Winston when Sapling fails
# AI_TEXT_DETECTOR_PROVIDER=auto
# Sapling (recommended for tweets) — must include https://
AI_DETECTOR_URL=https://api.sapling.ai/api/v1/aidetect
AI_DETECTOR_KEY=

# Optional detector tuning
# AI_DETECTOR_THRESHOLD=0.5
# AI_DETECTOR_TIMEOUT_MS=15000

# Sapling: use https://api.sapling.ai/api/v1/aidetect and your 32-char API key

# AI image detection (Winston AI recommended)
AI_IMAGE_DETECTOR_URL=https://api.gowinston.ai/v2/image-detection
AI_IMAGE_DETECTOR_KEY=

# Optional image detector tuning
# AI_IMAGE_DETECTOR_THRESHOLD=0.5
# AI_IMAGE_DETECTOR_TIMEOUT_MS=30000
# WINSTON_API_KEY=  (alias for AI_IMAGE_DETECTOR_KEY)

# Require active subscription for /api/detect (defaults to true in production)
# DETECT_REQUIRE_SUBSCRIPTION=true

# Neon Database
DATABASE_URL=

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: pre-created Stripe Price IDs (falls back to dynamic pricing)
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_STARTER_YEARLY=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_YEARLY=
# STRIPE_PRICE_BUSINESS_MONTHLY=
# STRIPE_PRICE_BUSINESS_YEARLY=
