# X / Twitter Developer API App (Vercel env vars)
# OAuth 2.0 app credentials from https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=

# Optional: OAuth 1.0a consumer keys (stored for reference / future use)
# X_API_KEY=
# X_API_SECRET=

# App-only bearer token for public post fetching (landing page / widget demo)
X_BEARER_TOKEN=

# Alternative env var names also supported:
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_BEARER_TOKEN=
# X_API_BEARER_TOKEN=

# OAuth callback URL (defaults to NEXT_PUBLIC_APP_URL + /api/connections/x/callback)
# Use 127.0.0.1 instead of localhost for local dev — X rejects localhost callbacks.
# X_REDIRECT_URI=http://127.0.0.1:3000/api/connections/x/callback

# Default X username to fetch posts from (optional, defaults to "natte")
X_DEFAULT_USERNAME=

# App base URL (used for OAuth redirect and Stripe checkout)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Optional: external AI detector
AI_DETECTOR_URL=
AI_DETECTOR_KEY=

# Neon Database
DATABASE_URL=

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: pre-created Stripe Price IDs (falls back to dynamic pricing)
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_STARTER_YEARLY=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_YEARLY=
# STRIPE_PRICE_BUSINESS_MONTHLY=
# STRIPE_PRICE_BUSINESS_YEARLY=
